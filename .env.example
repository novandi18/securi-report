# ╔═══════════════════════════════════════════════════════════╗
# ║              Securi Report — Environment Config              ║
# ║  Copy this file to .env.local and fill in real values.    ║
# ╚═══════════════════════════════════════════════════════════╝

# ─── App Environment ─────────────────────────────────────
# Set to "production" for production deployments.
# Set to "development" to enable dev-only features (seed banner, etc.)
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# ─── Database (MySQL 8) ─────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:your_password@localhost:3306/securi-report

# ─── NextAuth v5 ─────────────────────────────────────────
# Generate a secret: `openssl rand -base64 32`
AUTH_SECRET=your-auth-secret-here
# The canonical URL of your app (no trailing slash)
AUTH_URL=http://localhost:3000

# ─── SMTP (Email Notifications) ─────────────────────────
# Leave blank to disable email features (non-blocking)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Securi Report <noreply@example.com>"

# ─── Meilisearch (Instant Search) ───────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=your-meilisearch-master-key
# Search-only key (safe to expose to browser)
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=your-meilisearch-search-key

# ─── Gemini ─────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview
